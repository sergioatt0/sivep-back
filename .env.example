# .env.example — plantilla para .env.development.local
#
# Copiar a .env.development.local y ajustar los valores:
#   cp .env.example .env.development.local

# Entorno
NODE_ENV=development
PORT=5001

# SSL (requerido en desarrollo — ver carpeta certs/)
SSL_KEY_PATH=certs/private.key
SSL_CERT_PATH=certs/certificate.crt

# Orígenes permitidos por CORS (separados por coma)
ALLOWED_ORIGINS=http://localhost:3000,https://localhost:3000

# Base URL del API SISDEP (sin slash final).
# En producción, si no se define, el código usa https://www.medellin.gov.co/sisdep/back.
SISDEP_BASE_URL=https://sisdep.innovacion.it.com/sisdep/back
